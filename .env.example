# --- Required ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
GEMINI_API_KEY=your-gemini-api-key

# --- Telegram Scraper (for scraper.py) ---
# Get these at https://my.telegram.org
TELEGRAM_API_ID=your-api-id
TELEGRAM_API_HASH=your-api-hash
# TELEGRAM_SESSION_NAME=scraper_session

# --- Weaviate ---
WEAVIATE_URL=http://localhost:8080

# --- Embedding Model ---
# EMBEDDING_MODEL_NAME=Metric-AI/armenian-text-embeddings-1

# --- Chunking ---
# CHUNKING_STRATEGY=single_message    # single_message | sliding_window | conversation_thread
# CHUNK_WINDOW_SIZE=5
# CHUNK_OVERLAP=2
# THREAD_MAX_MESSAGES=20
# MIN_MESSAGE_LENGTH=0

# --- Ingestion ---
# INGEST_BATCH_SIZE=64

# --- HNSW Index ---
# HNSW_EF_CONSTRUCTION=128
# HNSW_MAX_CONNECTIONS=64
# HNSW_EF=256
# DISTANCE_METRIC=cosine              # cosine | dot | l2

# --- RAG Retrieval ---
# TOP_K=10
# MAX_DISTANCE=1.0

# --- Gemini Generation ---
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_TEMPERATURE=0.3
# GEMINI_MAX_OUTPUT_TOKENS=1024
# GEMINI_TOP_P=0.95
# GEMINI_TOP_K_SAMPLING=40
# SYSTEM_PROMPT=Your custom system prompt here
